# Docker
APP_PORT=8080
POSTGRES_DB=myzen
POSTGRES_USER=myzen
POSTGRES_PASSWORD=myzen
POSTGRES_PORT=5432

# Symfony
APP_ENV=dev
APP_SECRET=change_me_in_production_please_use_a_long_random_string
DEFAULT_URI=http://localhost:8080

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth — https://developers.facebook.com/apps/
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Apple Sign In — https://developer.apple.com/account/resources/authkeys/list
# Ключ положите в config/apple/AuthKey.p8
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?serverVersion=16&charset=utf8"

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###
